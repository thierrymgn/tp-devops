# CloudForge API — environment variables
# Copy this file to .env and adjust values for your setup.

# Express server port (must match VITE proxy / frontend VITE_API_URL)
PORT=3001

# Absolute or relative path to the Terraform modules root
# Your teammate's modules live here: <TERRAFORM_BASE_PATH>/<vm-type>/main.tf
TERRAFORM_BASE_PATH=../terraform

# Where .tfvars files are written at runtime (one per VM)
TFVARS_PATH=./terraform/envs

# Set to "production" on the server
NODE_ENV=development

# Optional: path to the terraform binary if not on $PATH
# TERRAFORM_BIN=terraform
